# ===========================================
# SiteGuard Monitor — Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://siteguard:siteguard_pass@localhost:5432/siteguard
POSTGRES_USER=siteguard
POSTGRES_PASSWORD=siteguard_pass
POSTGRES_DB=siteguard

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Security ---
SECRET_KEY=change-me-to-a-random-64-char-hex-string
LICENSE_SECRET_KEY=change-me-to-another-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Admin ---
ADMIN_EMAIL=admin@siteguard.app
ADMIN_PASSWORD=change-me-strong-password

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://87.228.29.55"]

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# --- Email (SMTP) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=alerts@siteguard.app
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=SiteGuard Monitor <alerts@siteguard.app>
SMTP_USE_SSL=true

# --- SMS ---
# SMS.RU
SMSRU_API_KEY=your-smsru-api-key
# SMSC.ru
SMSC_LOGIN=your-smsc-login
SMSC_PASSWORD=your-smsc-password
# SMS Aero
SMSAERO_EMAIL=your-email
SMSAERO_API_KEY=your-smsaero-key
SMS_PROVIDER=smsru

# --- VirusTotal ---
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# --- Firebase (Push Notifications) ---
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# --- Payments (YooKassa) ---
YOOKASSA_SHOP_ID=your-shop-id
YOOKASSA_SECRET_KEY=your-yookassa-secret
YOOKASSA_RETURN_URL=http://87.228.29.55/admin/payment/success

# --- Payments (Stripe) ---
STRIPE_SECRET_KEY=your-stripe-secret
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# --- Server ---
PROD_HOST=87.228.29.55
DOMAIN=siteguard.app

# --- Docker Registry ---
DOCKER_REGISTRY=registry.example.com
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# --- S3 (for releases) ---
AWS_S3_BUCKET=siteguard-releases
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# --- Android Signing ---
ANDROID_KEYSTORE_BASE64=base64-encoded-keystore
KEYSTORE_PASSWORD=your-keystore-password
KEY_ALIAS=siteguard
KEY_PASSWORD=your-key-password

# --- Google Play / RuStore ---
GOOGLE_PLAY_SERVICE_ACCOUNT=service-account-json
RUSTORE_TOKEN=your-rustore-token

# --- Code Signing (Windows) ---
CODE_SIGN_PASSWORD=your-certificate-password

# --- Telegram Deploy Notifications ---
TG_BOT_TOKEN=your-deploy-bot-token
TG_DEPLOY_CHAT=your-deploy-chat-id
